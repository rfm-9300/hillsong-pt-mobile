# Container Image
DOCKER_IMAGE_NAME=youruser/hillsong-pt-api:0.0.86

# Application Settings
PORT=8080
SPRING_PROFILES_ACTIVE=prod
IS_PRODUCTION=true
BASE_URL=https://your-domain.com

# JWT Security
# Generate a secure random string (min 32 chars)
JWT_SECRET=change_this_to_a_very_secure_random_string_of_at_least_32_chars
JWT_ISSUER=https://your-domain.com
JWT_AUDIENCE=users

# File Uploads
UPLOAD_PATH=/app/uploads

# Mail Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@your-domain.com

# OAuth2 (Optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Admin Configuration
ADMIN_TOKEN=change_this_admin_creation_token

# MinIO Configuration
MINIO_ENDPOINT=http://minio:9000
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=church-files
