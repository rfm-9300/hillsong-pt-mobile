# Supabase Configuration Template
# Copy this to .env to use Supabase instead of local DB

# Network: App needs to reach the internet, not just the 'db' container
# So in docker-compose, ensure the app container has internet access (default is yes)

# Update these with values from Supabase Dashboard -> Project Settings -> Database -> Connection string (JDBC)
# NOTE: Supabase requires SSL. The driver usually handles it with "?sslmode=require"
# Use the "Session" connection (Port 5432) for Spring Boot (HikariCP handles pooling).
# Avoid using the Transaction Pooler (Port 6543) unless you configure Hibernate to disable prepared statements.

DATABASE_URL=jdbc:postgresql://db.projectref.supabase.co:5432/postgres?sslmode=require&user=postgres&password=YOUR_PASSWORD

# These individual defaults are ignored if DATABASE_URL is set, 
# but good to keep clear or unset them.
# POSTGRES_HOST=db.projectref.supabase.co
# POSTGRES_DB=postgres
# POSTGRES_USERNAME=postgres.projectref
# POSTGRES_PASSWORD=YOUR_PASSWORD

# App Settings
PORT=8080
SPRING_PROFILES_ACTIVE=prod
IS_PRODUCTION=true
BASE_URL=https://your-domain.com

# Security & Mail (Same as before)
JWT_SECRET=change_this_to_a_very_secure_random_string_of_at_least_32_chars
JWT_ISSUER=https://your-domain.com
JWT_AUDIENCE=users
UPLOAD_PATH=/app/uploads
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@your-domain.com
